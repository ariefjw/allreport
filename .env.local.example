# Supabase — Dashboard → Settings → API Keys
# https://supabase.com/dashboard/project/_/settings/api-keys

NEXT_PUBLIC_SUPABASE_URL=https://ndacuzteojemxligxrug.supabase.co

# PUBLISHABLE key (safe for browser) — starts with sb_publishable_ or eyJ... (legacy anon)
# DO NOT put sb_secret_ or service_role key here!
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_9Edw96QmN2TB0qrp35q44g_dgAVzQGu

# SECRET key (server only, never expose to browser) — starts with sb_secret_
# Used only by /api/cron/daily-init — keep WITHOUT NEXT_PUBLIC_ prefix
SUPABASE_SERVICE_ROLE_KEY=sb_secret_your-key-here

# Operational timezone (WIB)
OPERATIONAL_TIMEZONE=Asia/Jakarta
NEXT_PUBLIC_OPERATIONAL_TIMEZONE=Asia/Jakarta

# Vercel Cron secret
CRON_SECRET=your-random-cron-secret
